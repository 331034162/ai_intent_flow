# ========== AI Intent Flow 配置模板 ==========
# 复制本文件为 .env 并按实际环境填写：
#   cp .env.example .env

# ========== 应用基础配置 ==========
APP_NAME=AI Intent Flow
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# ========== 外部接口域名 ==========
AIGC_WQ_DOMAIN=

# ========== 服务器配置 ==========
HOST=0.0.0.0
PORT=8000

# ========== MySQL 异步配置 ==========
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=info
MYSQL_POOL_SIZE=50
MYSQL_MAX_OVERFLOW=20
MYSQL_POOL_RECYCLE=3600
MYSQL_POOL_TIMEOUT=30

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATION=500 MB
LOG_RETENTION=30 days
LOG_COLORIZE=false
MY_POD_IP=127.0.0.1

# ========== 缓存刷新间隔配置 ==========
AI_INTENT_FLOW_WORKFLOW_CACHE_REFRESH_INTERVAL=60
AI_INTENT_FLOW_CONVERSATION_CACHE_REFRESH_INTERVAL=60
AI_INTENT_FLOW_NODE_PROMPT_CACHE_REFRESH_INTERVAL=60
